{
	"name": "nestjs-template",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"{src,test}/**/*.ts\"",
		"lint": "npx eslint \"{src,test}/**/*.ts\" --fix",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"test": "jest --runInBand",
		"infrastructure:up": "docker compose -f scripts/infrastructure.yaml up -d",
		"infrastructure:down": "docker compose -f scripts/infrastructure.yaml down",
		"test:create": "ts-node scripts/create-integration-tests.ts"
	},
	"dependencies": {
		"@nestjs/common": "10.4.15",
		"@nestjs/config": "^3.3.0",
		"@nestjs/core": "10.4.15",
		"@nestjs/platform-express": "10.4.15",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.1",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@eslint/js": "9.17.0",
		"@nestjs/cli": "10.4.9",
		"@nestjs/schematics": "10.2.3",
		"@nestjs/testing": "10.4.15",
		"@swc/core": "^1.10.9",
		"@swc/jest": "^0.2.37",
		"@types/express": "5.0.0",
		"@types/jest": "^29.5.14",
		"@types/node": "22.10.5",
		"axios": "1.7.9",
		"eslint": "9.17.0",
		"jest": "^29.7.0",
		"prettier": "3.4.2",
		"source-map-support": "0.5.21",
		"ts-jest": "^29.2.5",
		"ts-loader": "9.5.1",
		"ts-node": "10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.7.2",
		"typescript-eslint": "8.19.1"
	}
}
